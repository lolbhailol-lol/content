# CrwdCtrl Brain — Environment Variables

# --- Recommended: OpenRouter (multi-model, one key) ---
# Get key: https://openrouter.ai/keys
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash
# Free alternatives (may rotate): meta-llama/llama-3.3-70b-instruct:free, google/gemma-3-12b-it:free
OPENROUTER_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b

# --- Optional: Google Gemini direct ---
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Optional: OpenAI direct ---
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Force provider: openrouter | gemini | openai
# AI_PROVIDER=openrouter

# Optional — paths
# Default: CrwdCtrl-Brain/ if it exists, else project root
# DOCS_PATH=CrwdCtrl-Brain

# Where to store the vector index (default: .brain/vector-index.json)
# BRAIN_INDEX_PATH=.brain/vector-index.json

# Comma-separated extra directories to exclude from indexing
# DOCS_EXCLUDE_DIRS=brain,docs
